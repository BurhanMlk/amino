                <div className="flex items-center justify-between mb-8">
                    <h2 className="text-[#08202c] font-semibold text-[28px] md:text-[36px] font-['Poppins']">Highlight <span className="text-[#116190]">Products</span></h2>
                    <Link to="/products?filter=highlight" className="bg-[#116190] hover:bg-[#0c4a6e] text-white rounded-full px-6 py-2.5 flex items-center gap-2 font-medium text-[14px] transition-colors shadow-sm">
                        View All <ArrowRight className="w-4 h-4" />
                    </Link>
                </div>
                <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-4 gap-6">
                    {dummyProducts.slice(0, 4).map((p, i) => <ProductCard key={i} product={p} />)}
                </div>
            </section>

            {/* FAQ SECTION */}
            <section className="w-full max-w-[800px] mx-auto px-4 sm:px-6 lg:px-8 mt-24 mb-10 pb-20">
                <div className="flex flex-col items-center text-center mb-12">
                    <h2 className="text-[#08202c] font-semibold text-[32px] md:text-[40px] font-['Poppins']">Frequently Asked <span className="text-[#116190]">Questions</span></h2>
                </div>
                <div className="flex flex-col gap-4 w-full">
                    {faqs.map((faq, i) => (
                        <div key={i} className={`w-full rounded-[20px] overflow-hidden transition-all duration-300 ${i === 0 ? 'bg-[#116190] text-white shadow-lg' : 'bg-gray-50 hover:bg-gray-100'}`}>
                            <button className="w-full px-6 md:px-8 py-5 flex items-center justify-between text-left focus:outline-none group">
                                <span className={`font-semibold text-[16px] md:text-[18px] font-['Poppins'] ${i === 0 ? 'text-white' : 'text-[#08202c]'}`}>{faq.q}</span>
                                <div className={`shrink-0 ml-4 rounded-full p-1 transition-transform ${i === 0 ? 'bg-white/20 rotate-180' : 'bg-white shadow-sm text-[#116190] group-hover:bg-[#116190] group-hover:text-white'}`}>
                                    <ChevronDown className="w-5 h-5" />
                                </div>
                            </button>
                            {/* Simulate accordion open state for the first item */}
                            <div className={`px-6 md:px-8 pb-6 text-[15px] font-normal leading-relaxed ${i === 0 ? 'block text-gray-100' : 'hidden'}`}>
                                {faq.a}
                            </div>
                        </div>
                    ))}
                </div>
                <div className="flex w-full justify-center mt-8">
                    <button className="text-[#116190] border-b-2 border-[#116190] pb-1 font-semibold text-[16px] flex items-center gap-1 hover:text-[#0c4a6e] hover:border-[#0c4a6e] transition-colors">
                        View All FAQs <ArrowRight className="w-4 h-4" />
                    </button>
                </div>
            </section>

        </div>
    );
};

export default Home;
